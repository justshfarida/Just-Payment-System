{
  "Keycloak": {
    "Authority": "http://localhost:5055/auth/realms/JustPay",
    "ClientId": "just-pay-vue",
    "Audience": "account",
    "Issuer": "http://localhost:5055/auth/realms/JustPay",
    "MetadataAddress": "http://localhost:5055/auth/realms/JustPay/.well-known/openid-configuration"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "merchantRoutes": {
        "ClusterId": "merchantCluster",
        "Match": {
          "Path": "/merchants/{**catch-all}"
        },
        "Transforms": [{ "PathRemovePrefix": "/merchants" }]
      },
      "transactionRoutes": {
        "ClusterId": "transactionCluster",
        "Match": {
          "Path": "/transactions/{**catch-all}"
        },
        "Transforms": [{ "PathRemovePrefix": "/transactions" }]
      },
      "keycloakRoutes": {
        "ClusterId": "keycloakCluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        }
      },
      "clientRoutes": {
        "ClusterId": "clientCluster",
        "Match": {
          "Path": "{**catch-all}"
        }
      }
    },
    "Clusters": {
      "merchantCluster": {
        "Destinations": {
          "mercahntService": {
            "Address": "http://localhost:5019/"
          }
        }
      },
      "transactionCluster": {
        "Destinations": {
          "transactionService": {
            "Address": "http://localhost:5153/"
          }
        }
      },
      "keycloakCluster": {
        "Destinations": {
          "authService": {
            "Address": "http://localhost:8080/"
          }
        }
      },
      "clientCluster": {
        "Destinations": {
          "clientService": {
            "Address": "http://localhost:5173/"
          }
        }
      }
    }
  },
  "AllowedHosts": "*"
}
