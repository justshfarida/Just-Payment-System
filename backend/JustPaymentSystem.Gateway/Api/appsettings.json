{

  "Keycloak": {
    "Authority": "http://localhost:8080/realms/JustPay",
    "ClientId": "just-pay-vue",
    "Audience": "account",
    "Issuer": "http://localhost:8080/realms/JustPay",
    "MetadataAddress": "http://localhost:8080/realms/JustPay/.well-known/openid-configuration"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "merchantRoutes": {
        "ClusterId": "merchantCluster",
        "Match": {
          "Path": "/merchants/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "merchantCluster": {
        "Destinations": {
          "orderService": {
            "Address": "http://localhost:5019/"
          }
        }
      }
    }
  },
  "AllowedHosts": "*"
}
